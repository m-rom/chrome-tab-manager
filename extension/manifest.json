{
  "manifest_version": 3,
  "name": "Tab Manager",
  "version": "1.0.0",
  "description": "Alle Tabs nach Domain gruppiert im Side Panel verwalten",
  "permissions": ["tabs", "sidePanel", "storage", "activeTab"],
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["banner.js"],
    "css": ["banner.css"],
    "run_at": "document_idle"
  }],
  "action": {
    "default_title": "Tab Manager öffnen"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+M",
        "mac": "Command+M"
      },
      "description": "Open Tab Manager"
    }
  },
  "incognito": "spanning",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
