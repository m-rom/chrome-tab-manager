{
  "manifest_version": 3,
  "name": "Tab Manager",
  "version": "1.0.0",
  "description": "Alle Tabs nach Domain gruppiert im Side Panel verwalten",
  "permissions": ["tabs", "sidePanel", "storage"],
  "action": {
    "default_title": "Tab Manager öffnen"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "incognito": "spanning",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
